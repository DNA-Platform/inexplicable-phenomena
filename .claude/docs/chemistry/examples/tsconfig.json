{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "module": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "paths": {
      "@dna-platform/chemistry": ["../../../../library/chemistry/src/index.ts"],
      "@dna-platform/chemistry/*": ["../../../../library/chemistry/src/*"]
    }
  },
  "include": ["**/*.tsx", "**/*.ts"]
}
